<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentdash.server</string>
    <key>ProgramArguments</key>
    <array>
        <string>__PYTHON3__</string>
        <string>__DASH_DIR__/app.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__DASH_DIR__</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__DASH_DIR__/logs/server.log</string>
    <key>StandardErrorPath</key>
    <string>__DASH_DIR__/logs/server.err</string>
</dict>
</plist>
